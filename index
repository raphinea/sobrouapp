function cartaoFatura(cid,mk,statusFilter='todos'){
  return state.transacoes.filter(tx=>{
    const fm=tx.faturaMes||(tx.data?tx.data.substring(0,7):'');
    const statusOk = statusFilter==='todos' || tx.status===statusFilter;
    return tx.contaId===cid&&tx.tipo==='despesa'&&fm===mk&&statusOk;
  }).reduce((s,t)=>s+t.valor,0);
}

function proximoPagamento(){
  const dia=state.perfil?.diaPagamento||5;
  const diaUtil=state.perfil?.diaUtil||false;
  const hoje=new Date();
  let p=new Date(hoje.getFullYear(),hoje.getMonth(),1);
  if(diaUtil){
    // Find Nth business day of month
    let count=0;
    let d=new Date(p);
    while(true){
      const dow=d.getDay();
      if(dow!==0&&dow!==6){count++;if(count===dia)break;}
      d.setDate(d.getDate()+1);
    }
    p=new Date(d);
  } else {
    p=new Date(hoje.getFullYear(),hoje.getMonth(),dia);
  }
  if(p<=hoje){
    // Next month
    const nextMonth=new Date(hoje.getFullYear(),hoje.getMonth()+1,1);
    if(diaUtil){
      let count=0;let d=new Date(nextMonth);
      while(true){
        const dow=d.getDay();
        if(dow!==0&&dow!==6){count++;if(count===dia)break;}
        d.setDate(d.getDate()+1);
      }
      p=new Date(d);
    } else {
      p=new Date(hoje.getFullYear(),hoje.getMonth()+1,dia);
    }
  }
  return p;
}

function projectRecurrents(d){
  const mk = monthKey(d);

  state.recorrentes.forEach(r=>{
    // Garante que só projeta a partir do mês do lançamento de origem
    const dataInicioStr = r.dataInicio || (r.dia ? `${mk}-${String(Math.min(r.dia,28)).padStart(2,'0')}` : mk+'-01');
    const inicio = new Date(dataInicioStr + 'T00:00:00');
    const mesAtual = new Date(d.getFullYear(), d.getMonth(), 1);
    const mesInicio = new Date(inicio.getFullYear(), inicio.getMonth(), 1);

    if(mesAtual < mesInicio) return;

    // Se houver limite de repetições, verifica se já atingiu
    const repLimit = parseInt(r.repeticoes) || 0;
    if(repLimit > 0){
      // 1. Verifica pelo tempo decorrido
      const diffMeses = (mesAtual.getFullYear() - mesInicio.getFullYear()) * 12 + (mesAtual.getMonth() - mesInicio.getMonth());
      
      // 2. Verifica pela contagem de lançamentos já existentes para esta série
      const countExisting = state.transacoes.filter(t => t.recId === r.id).length;
      
      if(diffMeses >= repLimit || countExisting >= repLimit) return; 
    }

    const exists = state.transacoes.some(tx =>
      tx.recId === r.id &&
      tx.data &&
      tx.data.startsWith(mk)
    );

    if(exists) return;

    const dia = r.dia || 5;
    const data = `${mk}-${String(Math.min(dia,28)).padStart(2,'0')}`;

    // Número da parcela projetada
    let descProj = r.desc;
    if(repLimit > 0){
      const countSoFar = state.transacoes.filter(t=>t.recId===r.id).length;
      const nAtual = countSoFar + 1; // este será o próximo
      // Remove sufixo anterior se já existir (ex: ao reprojetar)
      const baseDesc = r.desc.replace(/ #\d+\/\d+$/, '');
      descProj = `${baseDesc} #${nAtual}/${repLimit}`;
    }
    const tx = {
      id: state.nextId++,
      tipo: r.tipo,
      desc: descProj,
      valor: r.valor,
      data,
      cat: r.cat,
      contaId: r.contaId,
      status: 'previsto',
      recId: r.id
    };

    state.transacoes.push(tx);
  });

  saveState();
}

