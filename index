function realizarTx(id){
  const tx=state.transacoes.find(t=>t.id===id);if(!tx)return;
  tx.status='realizado';
  if(tx.dividaId&&tx.tipo==='despesa'){const d=state.dividas.find(x=>x.id===tx.dividaId);if(d)d.saldo=Math.max(0,d.saldo-tx.valor);}
  saveState();renderCurrentPage();showToast('Marcado como realizado! ✅');
}

