<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>sobrou — seu dinheiro, descomplicado</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%20viewBox%3D%220%200%20100%20100%22%3E%3Cdefs%3E%3ClinearGradient%20id%3D%22g%22%20x1%3D%220%25%22%20y1%3D%220%25%22%20x2%3D%22100%25%22%20y2%3D%22100%25%22%3E%3Cstop%20offset%3D%220%25%22%20stop-color%3D%22%234ade80%22/%3E%3Cstop%20offset%3D%22100%25%22%20stop-color%3D%22%2316a34a%22/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect%20width%3D%22100%22%20height%3D%22100%22%20rx%3D%2224%22%20fill%3D%22url%28%23g%29%22/%3E%3Ccircle%20cx%3D%2250%22%20cy%3D%2255%22%20r%3D%2231%22%20fill%3D%22%23f0fdf4%22/%3E%3Ccircle%20cx%3D%2242%22%20cy%3D%2252%22%20r%3D%223%22%20fill%3D%22%2315803d%22/%3E%3Ccircle%20cx%3D%2258%22%20cy%3D%2252%22%20r%3D%223%22%20fill%3D%22%2315803d%22/%3E%3Cpath%20d%3D%22M41%2063%20Q50%2070%2059%2063%22%20stroke%3D%22%2315803d%22%20stroke-width%3D%222.5%22%20fill%3D%22none%22%20stroke-linecap%3D%22round%22/%3E%3Cellipse%20cx%3D%2244%22%20cy%3D%2225%22%20rx%3D%225%22%20ry%3D%228%22%20fill%3D%22%2386efac%22%20transform%3D%22rotate%28-25%2044%2025%29%22/%3E%3Cellipse%20cx%3D%2256%22%20cy%3D%2223%22%20rx%3D%225%22%20ry%3D%228%22%20fill%3D%22%234ade80%22%20transform%3D%22rotate%2820%2056%2023%29%22/%3E%3Cline%20x1%3D%2250%22%20y1%3D%2232%22%20x2%3D%2250%22%20y2%3D%2222%22%20stroke%3D%22%2316a34a%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22/%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#f7f8f5;--surface:#fff;--surface2:#f0f4f0;--border:#e4e9e1;
  --text:#111827;--text2:#6b7280;--text3:#9ca3af;
  --blue:#2563eb;--blue-light:#dbeafe;--blue-text:#1d4ed8;
  --green:#16a34a;--green-light:#dcfce7;--green-text:#15803d;
  --orange:#ea580c;--orange-light:#ffedd5;--orange-text:#c2410c;
  --red:#dc2626;--red-light:#fee2e2;--red-text:#b91c1c;
  --purple:#7c3aed;--purple-light:#ede9fe;
  --teal:#0d9488;--teal-light:#ccfbf1;
  --yellow:#ca8a04;--yellow-light:#fef9c3;
  --radius:14px;--radius-sm:8px;--radius-xs:6px;
  --sidebar-w:240px;
  --shadow-sm:0 1px 4px rgba(0,0,0,.05),0 1px 2px rgba(0,0,0,.03);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:14px}
body{font-family:'Inter',-apple-system,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;-webkit-font-smoothing:antialiased}
button{cursor:pointer;font-family:inherit}
input,select,textarea{font-family:inherit;font-size:14px}
.hidden{display:none!important}
.app{display:flex;min-height:100vh}
.sidebar{width:var(--sidebar-w);background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;position:fixed;top:0;left:0;bottom:0;z-index:100;overflow-y:auto}
.sidebar-logo{padding:16px 18px;border-bottom:1px solid var(--border);background:linear-gradient(135deg,#f0fdf4 0%,#fff 60%)}
.sidebar-logo em{color:#15803d;font-style:normal}
.sidebar-tagline{font-size:10px;font-weight:500;color:var(--text3);letter-spacing:.04em;text-transform:uppercase;margin-top:2px}
.sidebar-section{padding:18px 18px 6px;font-size:10px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.08em}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 12px;margin:2px 8px;border-radius:var(--radius-sm);color:var(--text2);cursor:pointer;font-size:13px;font-weight:500;border:none;background:none;width:calc(100% - 16px);text-align:left;transition:background .15s,color .15s}
.nav-item:hover{background:var(--surface2);color:var(--text)}
.nav-item.active{background:#dcfce7;color:#14532d;font-weight:600}
.nav-item svg{width:15px;height:15px;flex-shrink:0;opacity:.75}
.nav-item.active svg{opacity:1}
.sidebar-footer{margin-top:auto;padding:12px 10px;border-top:1px solid var(--border)}
.user-avatar{width:32px;height:32px;border-radius:50%;background:#dcfce7;color:#14532d;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;flex-shrink:0;overflow:hidden}
.user-avatar img{width:100%;height:100%;object-fit:cover}
.sidebar-accounts{padding:4px 8px 0}
.account-chip{display:flex;align-items:center;justify-content:space-between;padding:6px 12px;margin-bottom:1px;border-radius:var(--radius-sm);font-size:12.5px;cursor:pointer}
.account-chip:hover{background:var(--surface2)}
.account-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.btn-add-account{width:100%;padding:7px;border:1px dashed var(--border);border-radius:var(--radius-sm);background:none;color:var(--text3);font-size:12px;font-weight:500}
.btn-add-account:hover{border-color:#16a34a;color:#16a34a;background:var(--green-light)}
.main{flex:1;margin-left:var(--sidebar-w);display:flex;flex-direction:column;min-height:100vh}
.topbar{background:var(--surface);border-bottom:1px solid var(--border);padding:0 28px;height:56px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;position:sticky;top:0;z-index:50;box-shadow:0 1px 0 var(--border)}
.month-btn{width:30px;height:30px;border:1px solid var(--border);border-radius:var(--radius-xs);background:var(--surface);color:var(--text2);display:flex;align-items:center;justify-content:center;font-size:15px;transition:background .1s}
.month-btn:hover{background:var(--surface2)}
.month-label{font-size:14px;font-weight:600;min-width:140px;text-align:center}
.topbar-actions{display:flex;gap:8px}
.content{flex:1;padding:28px 32px}
.btn{padding:8px 16px;border-radius:var(--radius-sm);border:none;font-weight:600;font-size:13px;cursor:pointer;display:inline-flex;align-items:center;gap:6px;transition:opacity .1s,transform .1s;white-space:nowrap}
.btn:active{transform:scale(.98)}
.btn:hover{opacity:.9}
.btn-primary{background:#16a34a;color:#fff}.btn-primary:hover{background:#15803d}
.btn-success{background:var(--green);color:#fff}
.btn-ghost{background:none;border:1px solid var(--border);color:var(--text2)}
.btn-ghost:hover{background:var(--surface2);color:var(--text)}
.btn-danger{background:var(--red-light);color:var(--red-text);border:1px solid #fca5a5}
.btn-warn{background:var(--yellow-light);color:var(--yellow);border:1px solid #fde047}
.btn-sm{padding:5px 12px;font-size:12px}
.btn-icon{padding:5px 8px;background:none;border:1px solid var(--border);border-radius:var(--radius-xs);color:var(--text2);cursor:pointer;font-size:13px;transition:background .1s}
.btn-icon:hover{background:var(--surface2)}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:22px 24px;margin-bottom:16px;box-shadow:var(--shadow-sm)}
.card-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:16px}
.card-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:16px}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:16px}
.grid-2{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-bottom:16px}
.metric-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:18px 20px;box-shadow:var(--shadow-sm);transition:box-shadow .15s}
.metric-label{font-size:11.5px;color:var(--text2);margin-bottom:6px;font-weight:500}
.metric-value{font-size:22px;font-weight:800;color:var(--text);line-height:1.1}
.metric-value.green{color:var(--green)}
.metric-value.red{color:var(--red)}
.metric-value.orange{color:var(--orange)}
.metric-sub{font-size:11.5px;color:var(--text3);margin-top:4px}
.hero-card{background:linear-gradient(135deg,#14532d,#16a34a);border-radius:var(--radius);padding:28px 28px 24px;margin-bottom:20px;color:#fff;position:relative;overflow:hidden}
.hero-card::before{content:'';position:absolute;top:-40px;right:-40px;width:160px;height:160px;border-radius:50%;background:rgba(255,255,255,.06)}
.hero-greeting{font-size:14px;opacity:.7;margin-bottom:4px;font-weight:500}
.hero-next-pay{font-size:12.5px;opacity:.6;margin-bottom:20px;display:flex;align-items:center;gap:6px}
.hero-next-pay-badge{background:rgba(255,255,255,.15);padding:2px 8px;border-radius:20px;font-weight:600;font-size:12px}
.hero-question{font-size:11px;text-transform:uppercase;letter-spacing:.1em;opacity:.55;margin-bottom:6px;font-weight:600}
.hero-amount{font-size:52px;font-weight:800;line-height:1;letter-spacing:-2px;margin-bottom:6px}
.hero-amount.warn{color:#fbbf24}
.hero-amount.danger{color:#f87171}
.hero-sub{font-size:12.5px;opacity:.6}
.hero-stats{display:grid;grid-template-columns:repeat(3,1fr);margin-top:22px;padding-top:18px;border-top:1px solid rgba(255,255,255,.15)}
.hero-stat{text-align:center}
.hero-stat:not(:last-child){border-right:1px solid rgba(255,255,255,.1)}
.hero-stat-label{font-size:10px;text-transform:uppercase;letter-spacing:.06em;opacity:.5;margin-bottom:3px}
.hero-stat-value{font-size:14px;font-weight:700;opacity:.9}
.mes-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:16px}
.mes-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:18px 20px;box-shadow:var(--shadow-sm)}
.mes-card-icon{width:34px;height:34px;border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;margin-bottom:10px;font-size:16px}
.mes-card-label{font-size:11.5px;color:var(--text2);font-weight:500;margin-bottom:4px}
.mes-card-value{font-size:22px;font-weight:800;line-height:1.1}
.status-badge{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:20px;font-size:10.5px;font-weight:600}
.status-realizado{background:var(--green-light);color:var(--green-text)}
.status-previsto{background:var(--yellow-light);color:var(--yellow)}
.progress{height:5px;background:var(--surface2);border-radius:20px;overflow:hidden}
.progress-fill{height:100%;border-radius:20px;transition:width .5s ease}
.progress-lg{height:10px;background:var(--surface2);border-radius:20px;overflow:hidden;margin:8px 0}
.progress-lg .progress-fill{height:100%}
.table-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse}
th{text-align:left;font-size:10.5px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.07em;padding:10px 12px;border-bottom:1px solid var(--border)}
td{padding:10px 12px;border-bottom:1px solid var(--border);color:var(--text);font-size:13px}
tr:last-child td{border-bottom:none}
tr:hover td{background:var(--surface2)}
.td-val{font-weight:700;white-space:nowrap}
.td-val.pos{color:var(--green)}
.td-val.neg{color:var(--red)}
.td-val.previsto{opacity:.5}
.badge{display:inline-flex;align-items:center;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:600;white-space:nowrap}
.rec-tag,.prev-tag,.comp-tag,.transfer-tag{font-size:10px;padding:1px 5px;border-radius:8px;margin-left:4px}
.rec-tag{background:var(--green-light);color:var(--green-text)}
.transfer-tag{background:var(--purple-light);color:var(--purple)}
.prev-tag{background:var(--yellow-light);color:var(--yellow)}
.comp-tag{background:var(--teal-light);color:var(--teal)}
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.35);display:flex;align-items:center;justify-content:center;z-index:1000;backdrop-filter:blur(2px)}
.modal{background:var(--surface);border-radius:var(--radius);padding:24px;width:520px;max-width:96vw;max-height:92vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.18)}
.modal-title{font-size:16px;font-weight:700;margin-bottom:20px;display:flex;justify-content:space-between;align-items:center}
.modal-close{background:none;border:none;font-size:22px;color:var(--text3);cursor:pointer;line-height:1}
.modal-close:hover{color:var(--text)}
.form-group{margin-bottom:14px}
.form-label{display:block;font-size:12px;font-weight:600;color:var(--text2);margin-bottom:5px}
.form-control{width:100%;padding:9px 12px;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--surface);color:var(--text);outline:none;transition:border-color .15s;font-size:14px}
.form-control:focus{border-color:#16a34a;box-shadow:0 0 0 3px rgba(22,163,74,.1)}
.form-row{display:flex;gap:10px}
.form-row .form-group{flex:1}
.form-footer{display:flex;justify-content:flex-end;gap:8px;margin-top:20px;padding-top:16px;border-top:1px solid var(--border)}
.type-tabs{display:flex;border:1px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;margin-bottom:16px}
.type-tab{flex:1;padding:8px;text-align:center;cursor:pointer;font-size:13px;font-weight:600;border:none;background:none;color:var(--text2);transition:background .1s,color .1s}
.type-tab.active-despesa{background:var(--red-light);color:var(--red-text)}
.type-tab.active-receita{background:var(--green-light);color:var(--green-text)}
.type-tab.active-transferencia{background:var(--blue-light);color:var(--blue-text)}
.toggle-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border)}
.toggle-row:last-child{border-bottom:none}
.toggle{position:relative;width:36px;height:20px}
.toggle input{opacity:0;width:0;height:0}
.toggle-slider{position:absolute;inset:0;background:var(--border);border-radius:20px;cursor:pointer;transition:.2s}
.toggle-slider:before{content:'';position:absolute;width:14px;height:14px;left:3px;top:3px;background:#fff;border-radius:50%;transition:.2s}
.toggle input:checked+.toggle-slider{background:#16a34a}
.toggle input:checked+.toggle-slider:before{transform:translateX(16px)}
.filter-row{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px}
.filter-pill{padding:5px 14px;border-radius:20px;border:1px solid var(--border);background:var(--surface);color:var(--text2);font-size:12.5px;font-weight:500;cursor:pointer;transition:all .1s}
.filter-pill:hover{border-color:#16a34a;color:#16a34a}
.filter-pill.active{border-color:#16a34a;background:#dcfce7;color:#14532d;font-weight:600}
.page-tabs{display:flex;gap:4px;border-bottom:1px solid var(--border);margin-bottom:20px}
.page-tab{padding:8px 16px;font-size:13px;font-weight:600;background:none;border:none;border-bottom:2px solid transparent;color:var(--text2);cursor:pointer;margin-bottom:-1px}
.page-tab.active{color:#16a34a;border-bottom-color:#16a34a}
/* Tabs Meu Mês */
.meumes-tabs{display:flex;gap:8px;margin-bottom:20px}
.meumes-tab{padding:7px 16px;border-radius:20px;font-size:12.5px;font-weight:600;border:1.5px solid var(--border);background:var(--surface);color:var(--text2);cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:6px}
.meumes-tab:hover{border-color:#16a34a;color:#16a34a}
.meumes-tab.active{background:#16a34a;border-color:#16a34a;color:#fff}
.meumes-tab.active-green{background:#059669;border-color:#059669;color:#fff}
/* Hero verde benefícios */
.hero-card-ben{background:linear-gradient(135deg,#14532d,#16a34a);border-radius:var(--radius);padding:24px 28px 20px;color:#fff;margin-bottom:20px}
.hero-card-ben .hero-greeting{font-size:13px;opacity:.7;margin-bottom:2px}
.hero-card-ben .hero-question{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;opacity:.65;margin-bottom:8px}
.hero-card-ben .hero-amount{font-size:48px;font-weight:800;letter-spacing:-1.5px;line-height:1;margin-bottom:6px}
.hero-card-ben .hero-sub{font-size:13px;opacity:.65;margin-bottom:20px}
.hero-card-ben .hero-stats{display:grid;grid-template-columns:repeat(2,1fr);padding-top:16px;border-top:1px solid rgba(255,255,255,.15);margin-top:20px}
.hero-card-ben .hero-stat{text-align:center;padding:0 8px}
.hero-card-ben .hero-stat-label{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;opacity:.5;margin-bottom:4px}
.hero-card-ben .hero-stat-value{font-size:16px;font-weight:800}
/* Card benefício individual */
.ben-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px 22px;box-shadow:var(--shadow-sm)}
.ben-card-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px}
.ben-card-icon{width:36px;height:36px;border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:13px;flex-shrink:0}
.ben-card-saldo{font-size:26px;font-weight:800;color:var(--text);margin-bottom:2px}
.ben-card-disp{font-size:12px;color:var(--text3);margin-bottom:10px}
.chart-wrap{position:relative;height:210px}
.divida-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:18px 20px;margin-bottom:12px;box-shadow:var(--shadow-sm)}
.divida-stat-label{font-size:10.5px;color:var(--text3);margin-bottom:2px}
.divida-stat-value{font-size:14px;font-weight:700}
.objetivo-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:18px 20px;margin-bottom:12px;box-shadow:var(--shadow-sm)}
.benefit-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:18px 20px;box-shadow:var(--shadow-sm)}
.benefit-icon{width:40px;height:40px;border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;font-size:17px;font-weight:800;color:#fff;flex-shrink:0}
.benefit-saldo{font-size:22px;font-weight:800}
.benefit-saldo.ok{color:var(--green)}
.benefit-saldo.warn{color:var(--orange)}
.benefit-saldo.danger{color:var(--red)}
.cat-item{display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border)}
.cat-item:last-child{border-bottom:none}
.cat-color-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0}
.color-picker-row{display:flex;gap:7px;flex-wrap:wrap;margin-top:8px}
.color-opt{width:24px;height:24px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:transform .1s}
.color-opt:hover{transform:scale(1.15)}
.color-opt.selected{border-color:#fff;outline:2px solid var(--text)}
.emoji-grid{display:flex;flex-wrap:wrap;gap:6px;max-height:130px;overflow-y:auto;margin-top:6px}
.emoji-opt{width:34px;height:34px;display:flex;align-items:center;justify-content:center;font-size:20px;border-radius:8px;cursor:pointer;border:2px solid transparent;transition:all .1s}
.emoji-opt:hover{background:var(--surface2);transform:scale(1.1)}
.emoji-opt.selected{border-color:#16a34a;background:var(--green-light)}
.card-visual{width:100%;height:78px;border-radius:var(--radius);display:flex;align-items:flex-end;padding:14px;margin-bottom:14px;position:relative}
.card-visual-name{font-size:15px;font-weight:700;color:rgba(255,255,255,.95)}
.card-visual-limit{font-size:11px;color:rgba(255,255,255,.65);position:absolute;top:14px;right:16px}
.plan-row{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border)}
.plan-row:last-child{border-bottom:none}
.plan-label{flex:1;font-size:13px}
.plan-input{width:130px;padding:5px 8px;border:1px solid var(--border);border-radius:var(--radius-xs);font-size:13px;text-align:right}
.plan-real{width:120px;font-size:13px;font-weight:600;text-align:right}
.plan-diff{width:110px;font-size:12px;font-weight:600;text-align:right}
.trend-item{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--border);font-size:13px}
.trend-item:last-child{border-bottom:none}
.trend-badge{font-size:11px;padding:2px 8px;border-radius:20px;font-weight:600;min-width:50px;text-align:center}
.trend-up{background:var(--red-light);color:var(--red-text)}
.trend-down{background:var(--green-light);color:var(--green-text)}
.trend-neutral{background:var(--surface2);color:var(--text2)}
.summary-row{display:flex;gap:20px;padding:12px 0 0;border-top:1px solid var(--border);margin-top:4px}
.summary-item{font-size:12.5px;color:var(--text2)}
.summary-item span{font-weight:700}
.dot-blue{background:#2563eb}.dot-green{background:#16a34a}.dot-purple{background:#7c3aed}
.dot-orange{background:#ea580c}.dot-teal{background:#0d9488}.dot-red{background:#dc2626}
.dot-pink{background:#db2777}.dot-yellow{background:#d97706}.dot-gray{background:#6b7280}.dot-indigo{background:#4f46e5}
.empty-state{text-align:center;padding:40px 20px;color:var(--text3)}
.empty-state-icon{font-size:36px;margin-bottom:12px}
.empty-state-title{font-size:15px;font-weight:600;color:var(--text2);margin-bottom:6px}
.empty-state-sub{font-size:13px}
.mobile-menu-btn{display:none}
@media(max-width:768px){
  .sidebar{transform:translateX(-100%);transition:transform .25s}
  .sidebar.open{transform:translateX(0);box-shadow:4px 0 20px rgba(0,0,0,.15)}
  .main{margin-left:0}
  .mobile-menu-btn{display:flex;width:36px;height:36px;border:1px solid var(--border);border-radius:var(--radius-sm);background:none;align-items:center;justify-content:center;color:var(--text2);font-size:18px;cursor:pointer}
  .grid-4,.grid-3{grid-template-columns:repeat(2,1fr)}
  .hero-amount{font-size:36px}
  .mes-grid{grid-template-columns:repeat(2,1fr)}
  .content{padding:16px}
  .topbar{padding:0 16px}
}
</style>
</head>
<body>
