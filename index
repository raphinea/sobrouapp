function atualizarCalc(){
  const bruto=parseCurrency(document.getElementById('calc-bruto'));
  const aliq=parseFloat(document.getElementById('calc-aliq').value)||0;
  const res=document.getElementById('calc-resultado');
  if(bruto<=0){res.style.display='none';return;}
  const inss=Math.min(bruto*0.08,908.86);
  const ir=(bruto-inss)*(aliq/100);
  const liq=bruto-inss-ir;
  document.getElementById('calc-inss').textContent=fmt(inss);
  document.getElementById('calc-ir').textContent=fmt(ir);
  document.getElementById('calc-liq').textContent=fmt(liq);
  res.style.display='block';
}

