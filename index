async function saveTx(){
  const desc=document.getElementById('tx-desc').value.trim();
  const valor=parseCurrency(document.getElementById('tx-valor'));
  const data=document.getElementById('tx-data').value;
  const cat=document.getElementById('tx-cat').value;
  const contaId=parseInt(document.getElementById('tx-conta').value);
  const contaDestId=currentType==='transferencia'?parseInt(document.getElementById('tx-conta-dest').value):null;
  const isRec=document.getElementById('tx-recorrente').checked;
  const freq=document.getElementById('tx-freq').value;
  const rep=parseInt(document.getElementById('tx-repeticoes').value)||0;
  const co=getAccount(contaId);
  const faturaMes=(co&&co.tipo==='cartao'&&currentType==='despesa')?(document.getElementById('tx-fatura-mes-y').value+'-'+document.getElementById('tx-fatura-mes-m').value):null;
  // Para cartao: se nao tiver data preenchida, usa o 1o dia do mes da fatura como data da tx
  const dataFinal = (faturaMes && !data) ? faturaMes+'-01' : (data || new Date().toISOString().split('T')[0]);
  const dividaId=parseInt(document.getElementById('tx-divida-id').value)||null;
  const objetivoId=parseInt(document.getElementById('tx-objetivo-id').value)||null;
  const dataParaSalvar = dataFinal || data;
  if(!desc||isNaN(valor)||valor<=0||!dataParaSalvar||!contaId){dlgAlert('Campo obrigatório','Preencha todos os campos.','❗');return;}
  if(currentType==='transferencia'&&contaId===contaDestId){alert('Conta origem e destino iguais.');return;}
  // ── Escopo de edição de recorrente ──────────────────────
  // Se há escopo de edição de série recorrente, trata aqui e retorna
  // sem criar nova transação (evita duplicação)
  if(window._editRecScope && window._editRecId){
    const rec=state.recorrentes.find(r=>r.id===window._editRecId);
    if(rec){
      // Atualiza o template do recorrente
      rec.desc=desc; rec.valor=valor; rec.cat=cat; rec.contaId=contaId;
      rec.tipo=currentType; rec.freq=freq; rec.status=currentStatus;
      if(rep>0) rec.repeticoes=rep;
      if(dividaId) rec.dividaId=dividaId;

      if(window._editRecScope==='one'){
        // Só este: atualiza apenas a tx específica, quebra o vínculo com a série
        const oldTx=state.transacoes.find(t=>t.id===editingTxId);
        if(oldTx){
          oldTx.desc=desc; oldTx.valor=valor; oldTx.cat=cat;
          oldTx.contaId=contaId; oldTx.tipo=currentType;
          oldTx.status=currentStatus; oldTx.recId=null; // desvincula da série
        }
      } else if(window._editRecScope==='future'){
        // Atualiza a tx atual + todos os previstos futuros desta série
        const mkRef=editingTxId
          ? (state.transacoes.find(t=>t.id===editingTxId)?.data||dataParaSalvar).substring(0,7)
          : dataParaSalvar.substring(0,7);
        state.transacoes=state.transacoes.map(t=>{
          if(t.recId!==window._editRecId) return t;
          // Tx atual: atualiza independente de status
          if(t.id===editingTxId) return {...t,desc,valor,cat,contaId,tipo:currentType,status:currentStatus};
          // Futuros previstos: atualiza
          if(t.status==='previsto'&&t.data>=mkRef) return {...t,desc,valor,cat,contaId,tipo:currentType};
          return t;
        });
        // Remove previstos futuros para que projectRecurrents os recrie com dados novos
        state.transacoes=state.transacoes.filter(t=>
          !(t.recId===window._editRecId && t.status==='previsto' && t.data>mkRef)
        );
      } else if(window._editRecScope==='all'){
        // Atualiza TODOS os lançamentos desta série
        state.transacoes=state.transacoes.map(t=>{
          if(t.recId!==window._editRecId) return t;
          const isAtual=t.id===editingTxId;
          return {...t,desc,valor,cat,contaId,tipo:currentType,
            status:isAtual?currentStatus:t.status};
        });
      }
    }
    window._editRecScope=null; window._editRecId=null;
    saveState();closeTxModal();renderCurrentPage();showToast('Lançamento salvo! ✅');
    return; // sai sem criar nova tx
  }

  // ── Novo lançamento ou edição simples (não recorrente) ──
  let recId=null;
  if(isRec){
    recId='r'+state.nextId;
    const dia=parseInt(data.split('-')[2])||5;
    state.recorrentes.push({id:recId,tipo:currentType,desc,valor,cat,contaId,freq,
      repeticoes:rep,dia,dataInicio:data,status:currentStatus,dividaId});
  }
  const newId = editingTxId || state.nextId++;
  // Sufixo de parcela: recorrente com repetições definidas → "#1/N"
  const descFinal = (isRec && rep>0 && !editingTxId) ? `${desc} #1/${rep}` : desc;
  const tx={id:newId,tipo:currentType,desc:descFinal,valor,data:dataParaSalvar,cat,contaId,status:currentStatus};
  if(contaDestId)tx.contaDestId=contaDestId;if(recId)tx.recId=recId;if(faturaMes)tx.faturaMes=faturaMes;if(dividaId)tx.dividaId=dividaId;if(objetivoId)tx.objetivoId=objetivoId;
  if(editingTxId){
    const oldTx=state.transacoes.find(t=>t.id===editingTxId);
    if(oldTx&&oldTx.status==='realizado'&&oldTx.tipo==='despesa'){
      if(oldTx.dividaId){const d=state.dividas.find(x=>x.id===oldTx.dividaId);if(d)d.saldo=Math.min(d.saldoInicial||d.saldo+oldTx.valor,d.saldo+oldTx.valor);}

    }
    state.transacoes=state.transacoes.map(t=>t.id===editingTxId?tx:t);
  } else {
    state.transacoes.push(tx);
  }
  if(currentStatus==='realizado'&&dividaId&&currentType==='despesa'){const d=state.dividas.find(x=>x.id===dividaId);if(d)d.saldo=Math.max(0,d.saldo-valor);}
  // Objetivos não debitam conta — apenas indicativo
  saveState();closeTxModal();renderCurrentPage();showToast('Lançamento salvo! ✅');
}
async function editTx(id){
  const tx=state.transacoes.find(t=>t.id===id);
  if(!tx||!tx.recId){openTxModal(id);return;}
  const scope=await dlgChoice(
    'Editar lançamento recorrente',
    'Qual o escopo da edição?','✏️',[
      {label:'Só este mês',value:'one',primary:true},
      {label:'Este e os próximos',value:'future'},
      {label:'Todos (retroativo)',value:'all'},
    ]
  );
  if(!scope)return;
  if(scope==='one'){
    // Break this tx from the recorrente series — remove recId
    tx.recId=null;
    openTxModal(id);
  } else if(scope==='future'){
    window._editRecScope='future';
    window._editRecId=tx.recId;
    openTxModal(id);
  } else {
    window._editRecScope='all';
    window._editRecId=tx.recId;
    openTxModal(id);
  }
}
async function deleteTx(id){
  const tx=state.transacoes.find(t=>t.id===id);
  if(!tx)return;
  if(tx.recId){
    const choice=await dlgChoice('Lançamento recorrente','O que deseja excluir?','🔁',[
      {label:'Cancelar',value:'cancel'},
      {label:'Só este mês',value:'one'},
      {label:'Este e próximos',danger:true,value:'all'}
    ]);

    if(!choice || choice==='cancel') return; // usuário cancelou

    if(choice==='one'){
      // Remove apenas este lançamento, mantendo a série recorrente
      state.transacoes=state.transacoes.filter(t=>t.id!==id);
    } else if(choice==='all'){
      // Remove o template recorrente
      state.recorrentes=state.recorrentes.filter(r=>r.id!==tx.recId);
      // Remove este lançamento e todos os futuros (previstos) com esse recId
      const mkCurrent=tx.data.substring(0,7);
      state.transacoes=state.transacoes.filter(t=>
        !(t.id===id || (t.recId===tx.recId && t.status==='previsto' && t.data>=mkCurrent))
      );
    }
  } else {
    if(!await dlgDelete('lançamento'))return;
    state.transacoes=state.transacoes.filter(t=>t.id!==id);
  }
  saveState();renderCurrentPage();showToast('Lançamento removido.');
}

