        <div style="font-size:9px;font-weight:500;color:var(--text3);text-transform:uppercase;letter-spacing:.04em">Planejamento do Trabalhador</div>
      </div>
    </div>
  </div>
  <nav>
    <button class="nav-item active" data-page="meumes"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>Meu Mês</button>
    <button class="nav-item" data-page="cartoes"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>Cartões</button>
    <button class="nav-item" data-page="dividas"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>Dívidas</button>
    <button class="nav-item" data-page="objetivos"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>Objetivos</button>
    <div class="sidebar-section">Controle</div>
    <button class="nav-item" data-page="lancamentos"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>Lançamentos</button>
    <button class="nav-item" data-page="relatorios"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>Relatórios</button>
    <button class="nav-item" data-page="configuracoes"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>Configurações</button>
  </nav>
  <div style="padding:4px 0 8px">
    <div id="sidebar-accounts"></div>
  </div>
  <div class="sidebar-footer">
    <div style="display:flex;align-items:center;gap:10px;padding:6px 8px;border-radius:var(--radius-sm);cursor:pointer" onclick="openPerfilModal()">
      <div class="user-avatar" id="user-avatar-sidebar"><span id="user-avatar-initial">R</span></div>
      <div style="overflow:hidden;flex:1">
        <div style="font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" id="user-name-sidebar">Raphaella</div>
        <div style="font-size:11px;color:var(--text3)">CLT · Beta</div>
      </div>
      <button onclick="event.stopPropagation();doLogout()" title="Sair" style="background:none;border:none;cursor:pointer;color:var(--text3);font-size:16px;padding:4px;border-radius:6px;line-height:1" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text3)'">⏻</button>
    </div>
  </div>
</aside>
<div class="main">
  <header class="topbar">
    <div style="display:flex;align-items:center;gap:12px">
      <button class="mobile-menu-btn" onclick="toggleMobileMenu()">☰</button>
      <div style="display:flex;align-items:center;gap:10px">
        <button class="month-btn" onclick="changeMonth(-1)">&#8592;</button>
        <div class="month-label" id="month-label"></div>
        <button class="month-btn" onclick="changeMonth(1)">&#8594;</button>
      </div>
    </div>
    <div class="topbar-actions">
      <button class="btn btn-primary btn-sm" onclick="openTxModal()">+ Lançamento</button>
    </div>
  </header>
  <main class="content">
    <div id="page-meumes" class="page"></div>
    <div id="page-cartoes" class="page hidden"></div>
    <div id="page-dividas" class="page hidden"></div>
    <div id="page-objetivos" class="page hidden"></div>
    <div id="page-lancamentos" class="page hidden"></div>
    <div id="page-planejamento" class="page hidden"></div>
    <div id="page-relatorios" class="page hidden"></div>
    <div id="page-configuracoes" class="page hidden"></div>
  </main>
</div>
</div>
<!-- MODAIS -->
<div class="overlay hidden" id="tx-overlay">
<div class="modal">
  <div class="modal-title"><span id="tx-modal-title">Novo lançamento</span><button class="modal-close" onclick="closeTxModal()">&times;</button></div>
  <div class="type-tabs">
    <button class="type-tab active-despesa" data-type="despesa" onclick="setType('despesa')">Despesa</button>
    <button class="type-tab" data-type="receita" onclick="setType('receita')">Receita</button>
    <button class="type-tab" data-type="transferencia" onclick="setType('transferencia')">Transferência</button>
  </div>
  <div class="form-row">
    <div class="form-group" style="flex:2"><label class="form-label">Descrição</label><input class="form-control" id="tx-desc" placeholder="Ex: Supermercado"></div>
    <div class="form-group" style="flex:1"><label class="form-label">Valor (R$)</label><input class="form-control money" id="tx-valor" inputmode="numeric" placeholder="0,00"></div>
  </div>
  <div class="form-row">
    <div class="form-group" id="tx-data-group"><label class="form-label" id="tx-data-label">Data de vencimento</label><input class="form-control" id="tx-data" type="date"></div>
    <div class="form-group" id="tx-cat-group"><label class="form-label">Categoria</label><select class="form-control" id="tx-cat" onchange="onCatChange()"></select></div>
  </div>
  <div class="form-row">
    <div class="form-group" id="tx-conta-group"><label class="form-label" id="tx-conta-label">Conta</label><select class="form-control" id="tx-conta" onchange="onContaChange()"></select></div>
    <div class="form-group hidden" id="tx-conta-dest-group"><label class="form-label">Conta destino</label><select class="form-control" id="tx-conta-dest"></select></div>
  </div>
  <div class="form-group hidden" id="tx-fatura-group">
      <label class="form-label">Vencimento da fatura</label>
      <div style="display:flex;gap:8px">
        <select class="form-control" id="tx-fatura-mes-m" style="flex:1">
          <option value="01">Janeiro</option><option value="02">Fevereiro</option><option value="03">Março</option>
          <option value="04">Abril</option><option value="05">Maio</option><option value="06">Junho</option>
          <option value="07">Julho</option><option value="08">Agosto</option><option value="09">Setembro</option>
          <option value="10">Outubro</option><option value="11">Novembro</option><option value="12">Dezembro</option>
        </select>
        <select class="form-control" id="tx-fatura-mes-y" style="flex:1">
          <option value="2025">2025</option><option value="2026">2026</option><option value="2027">2027</option><option value="2028">2028</option>
        </select>
      </div>
    </div>
  <div class="form-group">
    <label class="form-label">Status</label>
    <div style="display:flex;border:1px solid var(--border);border-radius:8px;overflow:hidden">
      <button type="button" id="btn-s-prev" onclick="setStatus('previsto')" class="btn btn-warn btn-sm" style="flex:1;border-radius:0;border:none">🕐 Previsto</button>
      <button type="button" id="btn-s-real" onclick="setStatus('realizado')" class="btn btn-success btn-sm" style="flex:1;border-radius:0;border:none;border-left:1px solid var(--border);opacity:.4">✅ Realizado</button>
    </div>
    <div style="font-size:11px;color:var(--text3);margin-top:4px">Previsto não afeta o saldo das contas</div>
  </div>
  <div class="form-group hidden" id="tx-divida-group">
    <label class="form-label">Abater de qual dívida? <span style="font-size:10px;color:var(--text3)">(opcional)</span></label>
    <select class="form-control" id="tx-divida-id"><option value="">— Não abater —</option></select>
  </div>
  <div class="form-group hidden" id="tx-objetivo-group">
    <label class="form-label">Depositar em qual objetivo? <span style="font-size:10px;color:var(--text3)">(opcional)</span></label>
    <select class="form-control" id="tx-objetivo-id"><option value="">— Não vincular —</option></select>
  </div>
  <div class="toggle-row">
    <div><div style="font-size:13px;font-weight:600">Lançamento recorrente</div><div style="font-size:11.5px;color:var(--text3)">Replicar nos meses seguintes</div></div>
    <label class="toggle"><input type="checkbox" id="tx-recorrente" onchange="toggleRecorrente()"><span class="toggle-slider"></span></label>
  </div>
  <div id="rec-options" style="display:none;margin-top:10px;background:var(--green-light);border-radius:var(--radius-sm);padding:12px;border-left:3px solid var(--green)">
    <div class="form-row">
      <div class="form-group"><label class="form-label">Frequência</label><select class="form-control" id="tx-freq"><option value="mensal">Mensal</option><option value="anual">Anual</option></select></div>
      <div class="form-group"><label class="form-label">Repetições (0 = indefinido)</label><input class="form-control" id="tx-repeticoes" type="number" min="0" value="0"></div>
    </div>
  </div>
  <div class="form-footer">
    <button class="btn btn-ghost" onclick="closeTxModal()">Cancelar</button>
    <button class="btn btn-primary" onclick="saveTx()">Salvar</button>
  </div>
</div></div>

<div class="overlay hidden" id="account-overlay">
<div class="modal">
  <div class="modal-title"><span id="account-modal-title">Nova conta</span><button class="modal-close" onclick="closeAccountModal()">&times;</button></div>
  <div class="form-group"><label class="form-label">Nome</label><input class="form-control" id="ac-nome" placeholder="Ex: Nubank"></div>
  <div class="form-row">
    <div class="form-group"><label class="form-label">Tipo</label>
      <select class="form-control" id="ac-tipo" onchange="onAccountTypeChange()">
        <option value="corrente">Conta corrente</option><option value="poupanca">Poupança</option>
        <option value="cartao">Cartão de crédito</option><option value="beneficio">Cartão benefício (VA/VR/VT)</option><option value="investimento">Investimento</option><option value="carteira">Carteira</option>
      </select>
    </div>
    <div class="form-group"><label class="form-label">Cor</label>
      <select class="form-control" id="ac-cor">
        <option value="dot-blue">Azul</option><option value="dot-green">Verde</option><option value="dot-purple">Roxo</option>
        <option value="dot-orange">Laranja</option><option value="dot-teal">Teal</option><option value="dot-red">Vermelho</option>
        <option value="dot-pink">Rosa</option><option value="dot-indigo">Índigo</option>
      </select>
    </div>
  </div>
  <div class="form-group" id="ac-saldo-group"><label class="form-label">Saldo atual (R$)</label><input class="form-control money" id="ac-saldo" inputmode="numeric" placeholder="0,00"></div>
  <div class="form-group hidden" id="ac-bensal-group"><label class="form-label">Saldo mensal do benefício (R$)</label><input class="form-control money" id="ac-bensal" inputmode="numeric" placeholder="0,00"></div>
  <div class="form-group hidden" id="ac-limite-group"><label class="form-label">Limite do cartão (R$)</label><input class="form-control money" id="ac-limite" inputmode="numeric" placeholder="0,00"></div>
  <div class="form-footer">
    <button class="btn btn-ghost" onclick="closeAccountModal()">Cancelar</button>
    <button class="btn btn-primary" onclick="saveAccount()">Salvar</button>
  </div>
</div></div>

<div class="overlay hidden" id="objetivo-overlay">
<div class="modal">
  <div class="modal-title"><span id="objetivo-modal-title">Novo objetivo</span><button class="modal-close" onclick="closeObjetivoModal()">&times;</button></div>
  <div class="form-group"><label class="form-label">Escolha um emoji</label><div class="emoji-grid" id="emoji-picker"></div><input class="form-control" id="obj-emoji" maxlength="2" style="margin-top:8px;width:70px;text-align:center;font-size:18px"></div>
  <div class="form-group"><label class="form-label">Nome</label><input class="form-control" id="obj-nome" placeholder="Ex: Reserva de emergência"></div>
  <div class="form-row">
    <div class="form-group"><label class="form-label">Valor alvo (R$)</label><input class="form-control money" id="obj-alvo" inputmode="numeric" placeholder="0,00"></div>
    <div class="form-group"><label class="form-label">Prazo</label><input class="form-control" id="obj-prazo" type="date"></div>
  </div>
  <div class="form-group">
    <label class="form-label">Conta vinculada <span style="font-size:10px;color:var(--text3);font-weight:400">(opcional — saldo da conta = progresso)</span></label>
    <select class="form-control" id="obj-conta"><option value="">— Nenhuma —</option></select>
  </div>
  <div class="form-footer">
    <button class="btn btn-ghost" onclick="closeObjetivoModal()">Cancelar</button>
    <button class="btn btn-primary" onclick="saveObjetivo()">Salvar</button>
  </div>
</div></div>

<div class="overlay hidden" id="divida-overlay">
<div class="modal">
  <div class="modal-title"><span id="divida-modal-title">Nova dívida</span><button class="modal-close" onclick="closeDividaModal()">&times;</button></div>
  <div class="form-group"><label class="form-label">Nome / Credor</label><input class="form-control" id="div-nome" placeholder="Ex: Empréstimo XP"></div>
  <div class="form-row">
    <div class="form-group"><label class="form-label">Saldo devedor (R$)</label><input class="form-control money" id="div-saldo" inputmode="numeric" placeholder="0,00"></div>
    <div class="form-group"><label class="form-label">Parcela mensal (R$)</label><input class="form-control money" id="div-parcela" inputmode="numeric" placeholder="0,00"></div>
  </div>
  <div class="form-row">
    <div class="form-group"><label class="form-label">Juros (% a.m.)</label><input class="form-control" id="div-juros" type="number" min="0" step="0.01" value="0"></div>
    <div class="form-group"><label class="form-label">Quitação prevista</label><input class="form-control" id="div-data-final" type="date"></div>
  </div>
  <div class="form-group"><label class="form-label">Categoria de pagamento <span style="font-size:10px;color:var(--text3)">(lançamentos nessa cat. abaterão a dívida)</span></label><select class="form-control" id="div-cat"></select></div>
  <div class="form-footer">
    <button class="btn btn-ghost" onclick="closeDividaModal()">Cancelar</button>
    <button class="btn btn-primary" onclick="saveDivida()">Salvar</button>
  </div>
</div></div>

<div class="overlay hidden" id="benefit-overlay">
<div class="modal">
  <div class="modal-title"><span>Configurar benefício CLT</span><button class="modal-close" onclick="closeBenefitModal()">&times;</button></div>
  <div class="form-group"><label class="form-label">Tipo</label>
    <select class="form-control" id="ben-tipo" onchange="onBenTipoChange()">
      <option value="VA">Vale Alimentação (VA)</option><option value="VR">Vale Refeição (VR)</option>
      <option value="VT">Vale Transporte (VT)</option><option value="AHO">Auxílio Home Office</option><option value="OUT">Outro</option>
    </select>
  </div>
  <div class="form-group hidden" id="ben-nome-group"><label class="form-label">Nome</label><input class="form-control" id="ben-nome"></div>
  <div class="form-row">
    <div class="form-group"><label class="form-label">Saldo mensal (R$)</label><input class="form-control money" id="ben-saldo" inputmode="numeric" placeholder="0,00"></div>
    <div class="form-group"><label class="form-label">Cor</label>
      <select class="form-control" id="ben-cor">
        <option value="#0d9488">Teal</option><option value="#16a34a">Verde</option><option value="#2563eb">Azul</option>
        <option value="#ea580c">Laranja</option><option value="#7c3aed">Roxo</option>
      </select>
    </div>
  </div>
  <div class="form-group"><label class="form-label">Categoria associada</label><select class="form-control" id="ben-cat"></select></div>
  <div class="form-footer">
    <button class="btn btn-ghost" onclick="closeBenefitModal()">Cancelar</button>
    <button class="btn btn-primary" onclick="saveBenefit()">Salvar</button>
  </div>
</div></div>

<div class="overlay hidden" id="cat-overlay">
<div class="modal">
  <div class="modal-title"><span id="cat-modal-title">Nova categoria</span><button class="modal-close" onclick="closeCatModal()">&times;</button></div>
  <div class="form-group"><label class="form-label">Nome</label><input class="form-control" id="cat-nome"></div>
  <div class="form-group"><label class="form-label">Tipo</label><select class="form-control" id="cat-tipo"><option value="despesa">Despesa</option><option value="receita">Receita</option><option value="ambos">Ambos</option></select></div>
  <div class="form-group"><label class="form-label">Cor</label><div class="color-picker-row" id="cat-color-picker"></div></div>
  <div class="form-footer">
    <button class="btn btn-ghost" onclick="closeCatModal()">Cancelar</button>
    <button class="btn btn-primary" onclick="saveCat()">Salvar</button>
  </div>
</div></div>

<div class="overlay hidden" id="perfil-overlay">
<div class="modal">
  <div class="modal-title"><span>Meu perfil</span><button class="modal-close" onclick="closePerfilModal()">&times;</button></div>
  <div class="form-group" style="text-align:center">
    <label class="form-label" style="display:block;margin-bottom:8px">Foto de perfil</label>
    <div id="perfil-avatar-preview" style="width:72px;height:72px;border-radius:50%;background:var(--green-light);display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:700;color:var(--green-text);overflow:hidden;margin:0 auto 8px"></div>
    <label style="cursor:pointer;font-size:12px;color:var(--blue);font-weight:600">📷 Trocar foto<input type="file" accept="image/*" onchange="onProfilePhotoChange(event)" style="display:none"></label>
  </div>
  <div class="form-group"><label class="form-label">Nome</label><input class="form-control" id="perfil-nome" placeholder="Ex: Raphaella"></div>
  <div class="form-group"><label class="form-label">Dia do pagamento</label><input class="form-control" id="perfil-dia-pag" type="number" min="1" max="31"></div>
  <div class="form-footer">
    <button class="btn btn-ghost" onclick="closePerfilModal()">Cancelar</button>
    <button class="btn btn-primary" onclick="savePerfil()">Salvar</button>
  </div>
</div></div>
<!-- Auth Screen -->
<div id="auth-screen" style="position:fixed;inset:0;background:#f6f8fb;display:flex;align-items:center;justify-content:center;z-index:2000;padding:16px">
