}
function benefitBalance(cid,d){
  // Saldo real do beneficio: saldoMensal + aportes realizados - gastos realizados
  const c=getAccount(cid);if(!c)return 0;
  const txsMes=state.transacoes.filter(tx=>tx.contaId===cid&&tx.status==='realizado'&&txInMonth(tx,d));
