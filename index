function showDialog({icon='',title='',msg='',inputPlaceholder=null,btns=[{label:'OK',primary:true}]}){
  return new Promise(resolve=>{
    const ov=document.getElementById('dialog-overlay');
    document.getElementById('dialog-icon').textContent=icon;
    document.getElementById('dialog-title').textContent=title;
    document.getElementById('dialog-msg').textContent=msg;
    const iw=document.getElementById('dialog-input-wrap');
    const inp=document.getElementById('dialog-input');
    if(inputPlaceholder!==null){iw.style.display='block';inp.value='';inp.placeholder=inputPlaceholder;setTimeout(()=>inp.focus(),80);}
    else{iw.style.display='none';}
    const bc=document.getElementById('dialog-btns');
    bc.innerHTML='';
    btns.forEach(b=>{
      const btn=document.createElement('button');
      btn.textContent=b.label;
      btn.className='btn '+(b.primary?'btn-primary':b.danger?'btn-danger':'btn-ghost');
      btn.style.flex='1';
      btn.onclick=()=>{ov.style.display='none';resolve(b.value!==undefined?b.value:b.label);};
      bc.appendChild(btn);
    });
    ov.style.display='flex';
    inp.onkeydown=e=>{if(e.key==='Enter')bc.querySelector('.btn-primary')?.click();};
  });
}
async function dlgConfirm(title,msg,icon='⚠️'){
  return await showDialog({icon,title,msg,btns:[{label:'Cancelar',value:false},{label:'Confirmar',primary:true,value:true}]})===true;
}
async function dlgDelete(what){
  return await showDialog({icon:'🗑️',title:'Remover '+what,msg:'Essa ação não pode ser desfeita.',btns:[{label:'Cancelar',value:false},{label:'Remover',danger:true,value:true}]})===true;
}
async function dlgAlert(title,msg,icon='ℹ️'){
  await showDialog({icon,title,msg,btns:[{label:'OK',primary:true,value:true}]});
}
async function dlgPromptConfirm(title,msg,expected,icon='⚠️'){
  const r=await showDialog({icon,title,msg,inputPlaceholder:'Digite "'+expected+'" para confirmar',btns:[{label:'Cancelar',value:false},{label:'Confirmar',danger:true,value:'__confirm__'}]});
  if(r!=='__confirm__')return false;
  return document.getElementById('dialog-input').value.trim().toLowerCase()===expected.toLowerCase();
}
async function dlgChoice(title,msg,icon,btns){return await showDialog({icon,title,msg,btns});}


