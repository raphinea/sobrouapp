  const receitasPrev=sum(txs,'receita','previsto');
  const despesasPrev=sum(txs,'despesa','previsto');
  const saldoReal=receitas-despesas;
  const saldoPrev=(receitas+receitasPrev)-(despesas+despesasPrev);
  const statusLabel=filterStatus==='todos'?'Todos os status':filterStatus==='realizado'?'✅ Realizados':'🕐 Previstos';
