function renderAnual(){
  const ano=currentMonth.getFullYear();
  // Projetar recorrentes para todos os meses do ano
  for(let m=0;m<12;m++){
    projectRecurrents(new Date(ano,m,1));
  }

  const meses2=[];
  for(let m=0;m<12;m++) meses2.push(new Date(ano,m,1));

  const labels=meses2.map(d=>d.toLocaleString('pt-BR',{month:'short'}));

  // Dados por mês (realizado + previsto juntos para projeção)
  const rows=meses2.map(d=>{
    const txs=state.transacoes.filter(tx=>txInMonth(tx,d));
    const rec=txs.filter(t=>t.tipo==='receita').reduce((s,t)=>s+t.valor,0);
    const desp=txs.filter(t=>t.tipo==='despesa').reduce((s,t)=>s+t.valor,0);
    const saldo=rec-desp;
    const isReal=monthKey(d)<monthKey(currentMonth)||(monthKey(d)===monthKey(currentMonth)&&txs.some(t=>t.status==='realizado'));
    return{d,rec,desp,saldo,isReal,mk:monthKey(d)};
  });

  // Acumulado
  let acum=0;
  const acumArr=rows.map(r=>{acum+=r.saldo;return acum;});

  // Total do ano
  const totalRec=rows.reduce((s,r)=>s+r.rec,0);
  const totalDesp=rows.reduce((s,r)=>s+r.desp,0);
  const totalSaldo=totalRec-totalDesp;

  // Eventos especiais detectados nos lançamentos
  const eventos=[];
  rows.forEach(r=>{
    const txsEv2=state.transacoes.filter(tx=>txInMonth(tx,r.d));
    txsEv2.forEach(tx=>{
      if(tx.tipo==='receita'&&tx.cat==='receita_plr')eventos.push({mk:r.mk,label:'💼 PLR',valor:tx.valor,color:'var(--blue)'});
      if(tx.desc&&tx.desc.toLowerCase().includes('13º'))eventos.push({mk:r.mk,label:'🎄 13º Salário',valor:tx.valor,color:'var(--green)'});
      if(tx.desc&&tx.desc.toLowerCase().includes('férias'))eventos.push({mk:r.mk,label:'🏖️ Férias',valor:tx.valor,color:'var(--orange)'});
    });
    // Dívidas que quitam neste mês
    state.dividas.forEach(div=>{
      if(div.dataFinal&&div.dataFinal.substring(0,7)===r.mk)eventos.push({mk:r.mk,label:`🎉 Quita: ${div.nome}`,valor:div.parcela,color:'var(--green)'});
    });
  });

  const el=document.getElementById('page-anual');
  el.innerHTML=`
  <div class="card-header" style="margin-bottom:16px">
    <h2 style="font-size:18px;font-weight:700">Visão Anual — ${ano}</h2>
    <div style="display:flex;gap:8px">
      <button class="btn btn-ghost btn-sm" onclick="changeAnualYear(-1)">← ${ano-1}</button>
      <button class="btn btn-ghost btn-sm" onclick="changeAnualYear(1)">${ano+1} →</button>
    </div>
  </div>

  <!-- TOTAIS DO ANO -->
  <div class="grid-3" style="margin-bottom:16px">
    <div class="metric-card">
      <div class="metric-label">Receitas totais ${ano}</div>
      <div class="metric-value green">${fmt(totalRec)}</div>
      <div class="metric-sub">realizado + previsto</div>
    </div>
    <div class="metric-card">
      <div class="metric-label">Despesas totais ${ano}</div>
      <div class="metric-value red">${fmt(totalDesp)}</div>
      <div class="metric-sub">realizado + previsto</div>
    </div>
    <div class="metric-card">
      <div class="metric-label">Saldo acumulado ${ano}</div>
      <div class="metric-value ${totalSaldo>=0?'green':'red'}">${fmt(totalSaldo)}</div>
      <div class="metric-sub">${totalSaldo>=0?'sobra no ano':'déficit no ano'}</div>
    </div>
  </div>

  <!-- GRÁFICO -->
  <div class="card" style="margin-bottom:16px">
    <div class="card-title">Receitas vs Despesas — mês a mês</div>
    <div style="display:flex;gap:16px;margin-bottom:12px;font-size:12px;color:var(--text2)">
      <span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;border-radius:3px;background:var(--green)"></span>Receitas</span>
      <span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;border-radius:3px;background:var(--red)"></span>Despesas</span>
      <span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;border-radius:50%;background:var(--blue)"></span>Acumulado</span>
    </div>
    <div class="chart-wrap" style="height:240px"><canvas id="chart-anual"></canvas></div>
  </div>

  <!-- TABELA MENSAL -->
  <div class="card">
    <div class="card-title">Detalhamento mês a mês</div>
    <div class="table-wrap"><table>
      <thead><tr>
        <th>Mês</th>
        <th style="text-align:right">Receitas</th>
        <th style="text-align:right">Despesas</th>
        <th style="text-align:right">Saldo</th>
        <th style="text-align:right">Acumulado</th>
        <th>Status</th>
        <th>Destaques</th>
      </tr></thead>
      <tbody>
      ${rows.map((r,i)=>{
        const evMes=eventos.filter(e=>e.mk===r.mk);
        const isCurrent=r.mk===monthKey(currentMonth);
        const rowStyle=isCurrent?'background:var(--blue-light);':'';
        return`<tr style="${rowStyle}cursor:pointer" onclick="navigate('meumes');currentMonth=new Date(${r.d.getFullYear()},${r.d.getMonth()},1);document.getElementById('month-label').textContent=monthStr(currentMonth);renderCurrentPage()">
          <td style="font-weight:${isCurrent?'700':'500'}">${r.d.toLocaleString('pt-BR',{month:'long'})}</td>
          <td style="text-align:right;font-weight:600;color:var(--green)">${fmt(r.rec)}</td>
          <td style="text-align:right;font-weight:600;color:var(--red)">${fmt(r.desp)}</td>
          <td style="text-align:right;font-weight:700;color:${r.saldo>=0?'var(--green)':'var(--red)'}">${r.saldo>=0?'+':''}${fmt(r.saldo)}</td>
          <td style="text-align:right;font-weight:700;color:${acumArr[i]>=0?'var(--blue)':'var(--red)'}">${fmt(acumArr[i])}</td>
          <td><span class="status-badge ${r.isReal?'status-realizado':'status-previsto'}">${r.isReal?'✅ Real':'🕐 Prev'}</span></td>
          <td style="font-size:12px">${evMes.map(e=>`<span style="color:${e.color};font-weight:600">${e.label}</span>`).join(' ')}</td>
        </tr>`;
      }).join('')}
      </tbody>
    </table></div>
  </div>

  <!-- DÍVIDAS TIMELINE -->
  ${state.dividas.length?`
  <div class="card">
    <div class="card-title">Quitação de dívidas — cronograma</div>
    ${state.dividas.map(div=>{
      const mesesRest=div.parcela>0?Math.ceil(div.saldo/div.parcela):0;
      const pct=div.saldoInicial>0?Math.min(100,(1-div.saldo/div.saldoInicial)*100):0;
      return`<div style="margin-bottom:16px">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
          <div>
            <span style="font-weight:600;font-size:13.5px">${div.nome}</span>
            <span style="font-size:12px;color:var(--text3);margin-left:8px">Parcela: ${fmt(div.parcela)}/mês</span>
          </div>
          <div style="text-align:right">
            <div style="font-weight:700;color:var(--red)">${fmt(div.saldo)}</div>
            <div style="font-size:11px;color:var(--text3)">${div.dataFinal||'~'+mesesRest+' meses'}</div>
          </div>
        </div>
        <div class="progress-lg"><div class="progress-fill" style="width:${pct.toFixed(1)}%;background:${pct<30?'var(--red)':pct<70?'var(--orange)':'var(--green)'}"></div></div>
        <div style="font-size:11px;color:var(--text3);margin-top:3px">${pct.toFixed(1)}% quitado</div>
      </div>`;
    }).join('')}
  </div>`:''}`;

  // Renderizar gráfico
  destroyChart('anual');
  const recData=rows.map(r=>r.rec);
  const despData=rows.map(r=>r.desp);
  charts['anual']=new Chart(document.getElementById('chart-anual'),{
    type:'bar',
    data:{
      labels,
      datasets:[
        {label:'Receitas',data:recData,backgroundColor:'rgba(22,163,74,.7)',borderWidth:0,borderRadius:4,order:2},
        {label:'Despesas',data:despData,backgroundColor:'rgba(220,38,38,.7)',borderWidth:0,borderRadius:4,order:2},
        {label:'Acumulado',data:acumArr,type:'line',borderColor:'#2563eb',backgroundColor:'rgba(37,99,235,.1)',borderWidth:2,pointRadius:3,pointBackgroundColor:'#2563eb',tension:.3,fill:true,yAxisID:'y2',order:1},
      ]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      interaction:{mode:'index',intersect:false},
      plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>` ${ctx.dataset.label}: ${fmt(ctx.parsed.y)}`}}},
      scales:{
        x:{grid:{display:false}},
        y:{ticks:{callback:v=>'R$'+Math.abs(v/1000).toFixed(0)+'k'},grid:{color:'#e4e8ef'}},
        y2:{position:'right',ticks:{callback:v=>'R$'+Math.abs(v/1000).toFixed(0)+'k'},grid:{display:false}},
      }
    }
  });
}



