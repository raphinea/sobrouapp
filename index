// Applies BRL mask to a number input: shows "1.234,56" while user types
function maskCurrency(input){
  // Strip everything except digits
  let raw=input.value.replace(/\D/g,'');
  if(!raw){input.value='';return;}
  let cents=parseInt(raw,10);
  // Format as R$ style: last 2 digits = cents
  let val=(cents/100).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2});
  input.value=val;
}
function parseCurrency(input){
  // Convert masked display value back to float
  let v=input.value.replace(/\./g,'').replace(',','.');
  return parseFloat(v)||0;
}
