function calcLiquidoBonus(bruto,aliq){
  // Estimativa simples: desconta IR e 8% INSS sobre o bruto
  const inss=Math.min(bruto*0.08,908.86);
  const base=bruto-inss;
  const ir=base*(aliq/100);
  return bruto-inss-ir;
}

