async function saveBonus(){
  const nome=document.getElementById('bon-nome').value.trim();
  const tipo=document.getElementById('bon-tipo').value;
  const valorBruto=parseCurrency(document.getElementById('bon-bruto'));
  const aliquotaIR=parseFloat(document.getElementById('bon-aliq').value)||0;
  const mes=document.getElementById('bon-mes').value;
  if(!nome||isNaN(valorBruto)||valorBruto<=0){dlgAlert('Campo obrigatório','Preencha nome e valor.','❗');return;}
  if(editingBonusId){
    state.bonus=state.bonus.map(b=>b.id===editingBonusId?{...b,nome,tipo,valorBruto,aliquotaIR,mes}:b);
  } else {
    state.bonus.push({id:state.nextId++,nome,tipo,valorBruto,aliquotaIR,mes,pago:false});
  }
  saveState();closeBonusModal();refreshBonusViews();showToast('Bônus salvo! ✅');
}
async function deleteBonus(id){
  if(!await dlgDelete('bônus'))return;
  state.bonus=state.bonus.filter(b=>b.id!==id);saveState();refreshBonusViews();
}
async function marcarBonusPago(id){
  const b=state.bonus.find(x=>x.id===id);if(!b)return;
  b.pago=true;
  // Optionally create a receita transaction
  const liq=calcLiquidoBonus(b.valorBruto,b.aliquotaIR||0);
  if(confirm(`Marcar "${b.nome}" como recebido?\n\nDeseja também lançar ${fmt(liq)} como receita em Lançamentos?`)){
    const hoje=new Date().toISOString().split('T')[0];
    state.transacoes.push({id:state.nextId++,tipo:'receita',desc:b.nome,valor:liq,data:hoje,cat:'receita_plr',contaId:state.contas[0]?.id||1,status:'realizado'});
  }
  saveState();refreshBonusViews();showToast('Bônus marcado como recebido! 🎉');
}

