// Calcula receitas+despesas de recorrentes para um mes futuro sem criar txs
function recurrentesParaMes(d){
  const mk=monthKey(d);
  const mesD=new Date(d.getFullYear(),d.getMonth(),1);
  let rec=0,desp=0;
  state.recorrentes.forEach(r=>{
    const inicio=new Date((r.dataInicio||mk+'-01')+'T00:00:00');
    const mesInicio=new Date(inicio.getFullYear(),inicio.getMonth(),1);
    if(mesD<mesInicio)return;
    const repLimit=parseInt(r.repeticoes)||0;
    if(repLimit>0){
      const diffMeses=(mesD.getFullYear()-mesInicio.getFullYear())*12+(mesD.getMonth()-mesInicio.getMonth());
      if(diffMeses>=repLimit)return;
    }
    if(r.tipo==='receita')rec+=r.valor;
    else if(r.tipo==='despesa')desp+=r.valor;
  });
  return{rec,desp};
}

function renderAnual(){
  const ano=currentMonth.getFullYear();
  // So projeta recorrentes ate o mes atual (nao cria txs em meses futuros)
  const mkAtual=monthKey(currentMonth);
  for(let m=0;m<12;m++){
    const d=new Date(ano,m,1);
    if(monthKey(d)<=mkAtual) projectRecurrents(d);
  }

  const meses=[];
  for(let m=0;m<12;m++) meses.push(new Date(ano,m,1));

  const labels=meses.map(d=>d.toLocaleString('pt-BR',{month:'short'}));

  // Dados por mes: passados/atual usam txs reais; futuros usam recorrentes diretamente
  const rows=meses.map(d=>{
    const mk=monthKey(d);
    const isFuturo=mk>mkAtual;
    const txs=state.transacoes.filter(tx=>txInMonth(tx,d));
    let rec,desp;
    if(isFuturo){
      const proj=recurrentesParaMes(d);
      rec=proj.rec; desp=proj.desp;
    } else {
      rec=txs.filter(t=>t.tipo==='receita').reduce((s,t)=>s+t.valor,0);
      desp=txs.filter(t=>t.tipo==='despesa').reduce((s,t)=>s+t.valor,0);
    }
    const saldo=rec-desp;
    const isReal=mk<mkAtual||(mk===mkAtual&&txs.some(t=>t.status==='realizado'));
    return{d,rec,desp,saldo,isReal,mk};
  });

  // Acumulado
  let acum=0;
  const acumArr=rows.map(r=>{acum+=r.saldo;return acum;});

  // Total do ano
  const totalRec=rows.reduce((s,r)=>s+r.rec,0);
  const totalDesp=rows.reduce((s,r)=>s+r.desp,0);
  const totalSaldo=totalRec-totalDesp;

  // Eventos especiais detectados nos lançamentos
  const eventos=[];
  rows.forEach(r=>{
    const txsEv=state.transacoes.filter(tx=>txInMonth(tx,r.d));
    txsEv.forEach(tx=>{
      if(tx.tipo==='receita'&&tx.cat==='receita_plr')eventos.push({mk:r.mk,label:'💼 PLR',valor:tx.valor,color:'var(--blue)'});
      if(tx.desc&&tx.desc.toLowerCase().includes('13º'))eventos.push({mk:r.mk,label:'🎄 13º Salário',valor:tx.valor,color:'var(--green)'});
      if(tx.desc&&tx.desc.toLowerCase().includes('férias'))eventos.push({mk:r.mk,label:'🏖️ Férias',valor:tx.valor,color:'var(--orange)'});
    });
    // Dívidas que quitam neste mês
    state.dividas.forEach(div=>{
      if(div.dataFinal&&div.dataFinal.substring(0,7)===r.mk)eventos.push({mk:r.mk,label:`🎉 Quita: ${div.nome}`,valor:div.parcela,color:'var(--green)'});
    });
  });

  const el=document.getElementById('page-anual');
  el.innerHTML=`
