function importJSON(e){const f=e.target.files[0];if(!f)return;const r=new FileReader();r.onload=ev=>{try{state=JSON.parse(ev.target.result);saveState();renderCurrentPage();renderSidebar();showToast('Backup importado! ✅');}catch{dlgAlert('Erro','Arquivo inválido ou corrompido.','❌');}};r.readAsText(f);}
function exportCSV(){const rows=[['Data','Tipo','Status','Descrição','Categoria','Conta','Valor']];state.transacoes.sort((a,b)=>a.data.localeCompare(b.data)).forEach(tx=>{rows.push([tx.data,tx.tipo,tx.status||'realizado',tx.desc,getCat(tx.cat).nome,getAccount(tx.contaId)?.nome||'?',(tx.tipo==='receita'?1:-1)*tx.valor]);});const csv=rows.map(r=>r.map(v=>`"${String(v).replace(/"/g,'""')}"`).join(',')).join('\n');download('lancamentos.csv','data:text/csv;charset=utf-8,\uFEFF'+encodeURIComponent(csv));}
