function renderLancamentos(){
  let txs=state.transacoes.filter(tx=>txInMonth(tx,currentMonth));
  if(filterTipo!=='todos')txs=txs.filter(t=>t.tipo===filterTipo);
  if(filterStatus!=='todos')txs=txs.filter(t=>t.status===filterStatus);
  if(filterConta!=='todos')txs=txs.filter(t=>String(t.contaId)===String(filterConta));
  if(filterCat!=='todos')txs=txs.filter(t=>t.cat===filterCat);
  // Ordenação
  txs.sort((a,b)=>{
    if(filterSort==='data-desc')return b.data.localeCompare(a.data);
    if(filterSort==='data-asc')return a.data.localeCompare(b.data);
    if(filterSort==='desc-asc')return a.desc.localeCompare(b.desc);
    if(filterSort==='desc-desc')return b.desc.localeCompare(a.desc);
