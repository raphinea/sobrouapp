    <select style="padding:6px 10px;border:1px solid var(--border);border-radius:8px;font-size:12.5px;font-family:inherit;background:var(--surface);color:var(--text);cursor:pointer" onchange="filterConta=this.value;renderLancamentos()">${contaOpts}</select>
