function renderRelAnual(){
  const ano=currentMonth.getFullYear();
  const mkAtual=monthKey(currentMonth);
  for(let m=0;m<12;m++){
    const d=new Date(ano,m,1);
    if(monthKey(d)<=mkAtual) projectRecurrents(d);
  }
  const meses=[];for(let m=0;m<12;m++)meses.push(new Date(ano,m,1));
  const labels=meses.map(d=>d.toLocaleString('pt-BR',{month:'short'}));
  const rows=meses.map(d=>{
    const mk=monthKey(d);
    const isFuturo=mk>mkAtual;
    const txs=state.transacoes.filter(tx=>txInMonth(tx,d));
    let rec,desp;
    if(isFuturo){
      const proj=recurrentesParaMes(d);
      rec=proj.rec; desp=proj.desp;
    } else {
      rec=txs.filter(t=>t.tipo==='receita').reduce((s,t)=>s+t.valor,0);
      desp=txs.filter(t=>t.tipo==='despesa').reduce((s,t)=>s+t.valor,0);
    }
    return{d,rec,desp,saldo:rec-desp,mk};
  });
  let acum=0;const acumArr=rows.map(r=>{acum+=r.saldo;return acum;});
  const totalRec=rows.reduce((s,r)=>s+r.rec,0);
  const totalDesp=rows.reduce((s,r)=>s+r.desp,0);
  document.getElementById('rel-anual').innerHTML=`
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
    <h3 style="font-size:16px;font-weight:700">${ano}</h3>
    <div style="display:flex;gap:8px">
      <button class="btn btn-ghost btn-sm" onclick="changeAnualYear(-1)">← ${ano-1}</button>
      <button class="btn btn-ghost btn-sm" onclick="changeAnualYear(1)">${ano+1} →</button>
    </div>
  </div>
  <div class="grid-3" style="margin-bottom:16px">
    <div class="metric-card"><div class="metric-label">Receitas ${ano}</div><div class="metric-value green">${fmt(totalRec)}</div></div>
    <div class="metric-card"><div class="metric-label">Despesas ${ano}</div><div class="metric-value red">${fmt(totalDesp)}</div></div>
    <div class="metric-card"><div class="metric-label">Saldo ${ano}</div><div class="metric-value ${totalRec-totalDesp>=0?'green':'red'}">${fmt(totalRec-totalDesp)}</div></div>
  </div>
  <div class="card"><div class="card-title">Mês a mês</div><div class="chart-wrap" style="height:240px"><canvas id="chart-anual"></canvas></div></div>
  <div class="card"><div class="card-title">Detalhamento</div><div class="table-wrap"><table>
    <thead><tr><th>Mês</th><th style="text-align:right">Receitas</th><th style="text-align:right">Despesas</th><th style="text-align:right">Saldo</th><th style="text-align:right">Acumulado</th></tr></thead>
    <tbody>${rows.map((r,i)=>{
      const isCurr=r.mk===monthKey(currentMonth);
      return`<tr style="${isCurr?'background:var(--blue-light)':''};cursor:pointer" onclick="currentMonth=new Date(${r.d.getFullYear()},${r.d.getMonth()},1);document.getElementById('month-label').textContent=monthStr(currentMonth);navigate('meumes')">
        <td style="font-weight:${isCurr?'700':'500'}">${r.d.toLocaleString('pt-BR',{month:'long'})}</td>
        <td style="text-align:right;color:var(--green);font-weight:600">${fmt(r.rec)}</td>
        <td style="text-align:right;color:var(--red);font-weight:600">${fmt(r.desp)}</td>
        <td style="text-align:right;font-weight:700;color:${r.saldo>=0?'var(--green)':'var(--red)'}">${r.saldo>=0?'+':''}${fmt(r.saldo)}</td>
        <td style="text-align:right;font-weight:700;color:${acumArr[i]>=0?'var(--blue)':'var(--red)'}">${fmt(acumArr[i])}</td>
      </tr>`;
    }).join('')}</tbody>
  </table></div></div>`;
  destroyChart('anual');
  charts['anual']=new Chart(document.getElementById('chart-anual'),{type:'bar',data:{labels,datasets:[
    {label:'Receitas',data:rows.map(r=>r.rec),backgroundColor:'rgba(22,163,74,.7)',borderWidth:0,borderRadius:4,order:2},
    {label:'Despesas',data:rows.map(r=>r.desp),backgroundColor:'rgba(220,38,38,.7)',borderWidth:0,borderRadius:4,order:2},
    {label:'Acumulado',data:acumArr,type:'line',borderColor:'#2563eb',backgroundColor:'rgba(37,99,235,.1)',borderWidth:2,pointRadius:3,tension:.3,fill:true,yAxisID:'y2',order:1},
  ]},options:{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},plugins:{legend:{display:false}},scales:{x:{grid:{display:false}},y:{ticks:{callback:v=>'R$'+(v/1000).toFixed(0)+'k'}},y2:{position:'right',ticks:{callback:v=>'R$'+(v/1000).toFixed(0)+'k'},grid:{display:false}}}}});
}

