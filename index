function accountBalance(cid,mesRef){
  const c=getAccount(cid);if(!c)return 0;
  const refMes=mesRef||currentMonth;
  // Cartao de credito: saldo = fatura realizada do mes de referencia
  if(c.tipo==='cartao'){
    const mk=monthKey(refMes);
    return cartaoFatura(cid,mk,'realizado');
  }
  // Beneficio: saldoMensal + aportes realizados no mes - gastos realizados no mes
  if(c.tipo==='beneficio'){
    const txsMes=state.transacoes.filter(tx=>tx.contaId===cid&&tx.status==='realizado'&&txInMonth(tx,refMes));
    const aportes=txsMes.filter(tx=>tx.tipo==='receita').reduce((s,t)=>s+t.valor,0);
    const gastos=txsMes.filter(tx=>tx.tipo==='despesa').reduce((s,t)=>s+t.valor,0);
    return (c.saldoMensal||0)+aportes-gastos;
  }
  let b=c.saldoInicial||0;
  state.transacoes.forEach(tx=>{
    if(tx.status!=='realizado')return;
    if(tx.tipo==='receita'&&tx.contaId===cid)b+=tx.valor;
    if(tx.tipo==='despesa'&&tx.contaId===cid)b-=tx.valor;
    if(tx.tipo==='transferencia'){if(tx.contaId===cid)b-=tx.valor;if(tx.contaDestId===cid)b+=tx.valor;}
  });
  return b;
}

function monthTotals(d){
  // Coleta IDs de contas que NAO sao dinheiro (cartao credito e beneficio)
  // Usa Set de IDs para lookup O(1) e nao depende de tipo estar correto no cadastro
  const contasNaoDinheiro=new Set(
    state.contas.filter(c=>c.tipo==='cartao'||c.tipo==='beneficio').map(c=>c.id)
  );
  const txs=state.transacoes.filter(tx=>{
    if(!txInMonth(tx,d)) return false;
    // Exclui txs de cartao e beneficio; se conta nao encontrada tambem exclui
    if(contasNaoDinheiro.has(tx.contaId)) return false;
    const c=getAccount(tx.contaId);
    return !!c; // so inclui se a conta existe
  });
  const real=txs.filter(t=>t.status==='realizado');
  const prev=txs.filter(t=>t.status==='previsto');
  return{
    receitas:real.filter(t=>t.tipo==='receita').reduce((s,t)=>s+t.valor,0),
    despesas:real.filter(t=>t.tipo==='despesa').reduce((s,t)=>s+t.valor,0),
    receitasPrev:prev.filter(t=>t.tipo==='receita').reduce((s,t)=>s+t.valor,0),
    despesasPrev:prev.filter(t=>t.tipo==='despesa').reduce((s,t)=>s+t.valor,0),
  };
}

function catTotalsMonth(d,st='realizado'){
  const TIPOS_DINHEIRO=new Set(['corrente','poupanca','carteira','investimento']);
