  const despData=rows.map(r=>r.desp);
  charts['anual']=new Chart(document.getElementById('chart-anual'),{
    type:'bar',
    data:{
      labels,
      datasets:[
        {label:'Receitas',data:recData,backgroundColor:'rgba(22,163,74,.7)',borderWidth:0,borderRadius:4,order:2},
