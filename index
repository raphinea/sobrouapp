  return`<tr><td style="color:var(--text3);font-size:12px;white-space:nowrap">${tx.data}</td><td style="font-weight:500">${tx.desc}${tx.recId&&tx.status==='previsto'?'<span class="rec-tag">recorrente</span>':""}${tx.dividaId?'<span class="comp-tag">dívida</span>':''}</td><td>${catBadge}</td><td style="color:var(--text2);font-size:12px">${conta?.nome||'?'}</td><td><span class="status-badge ${isPrev?'status-previsto':'status-realizado'}">${isPrev?'🕐':'✅'}</span></td><td>${val}</td>${act}</tr>`;
