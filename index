(async()=>{
  // MODO LOCAL: pula auth, carrega direto do localStorage
  if(IS_LOCAL){
    const banner=document.createElement('div');
    banner.style.cssText='position:fixed;top:0;left:0;right:0;background:#fef9c3;border-bottom:1px solid #fde047;padding:6px 16px;font-size:12px;color:#854d0e;z-index:9999;text-align:center;font-weight:500';
    banner.textContent='⚡ Modo local — dados salvos só neste browser. Para usar com nuvem, acesse pelo Netlify.';
    document.body.prepend(banner);
    const localState = loadStateLocal();
    if(localState) state = localState;
    document.getElementById('auth-screen').style.display='none';
    document.getElementById('month-label').textContent=monthStr(currentMonth);
    projectRecurrents(currentMonth);
    navigate('meumes');
    return;
  }
  // Detecta se voltou de um link de confirmação de e-mail
  // (o Supabase coloca o token na URL como hash fragment)
  const hash=window.location.hash;
  if(hash&&(hash.includes('access_token')||hash.includes('error'))){
    // Tem fragmento de auth na URL — deixa o onAuthStateChange resolver
    if(hash.includes('error')){
      // Link expirado ou inválido
      setTimeout(()=>{
        setAuthMsg('Link de confirmação expirado. Crie a conta novamente.',true);
      },500);
    }
    // Limpa o hash da URL sem recarregar
    history.replaceState(null,'',window.location.pathname);
  }

  // Verifica sessão existente (usuário já logado antes)
  if(!sb){return;}
  const{data:{session}}=await sb.auth.getSession();
  if(session){
    await onLogin(session.user);
    return;
  }

  // Escuta mudanças de auth (confirmação de e-mail, logout)
  if(sb) sb.auth.onAuthStateChange(async(event,session)=>{
    if((event==='SIGNED_IN'||event==='TOKEN_REFRESHED')&&session&&!currentUser){
      await onLogin(session.user);
    }
    if(event==='SIGNED_OUT'){
      currentUser=null;
      location.reload(); // Recarrega limpo
    }
  });
})();
